# Teacher dashboard — required on Vercel (Production + Preview + Development)
# Do NOT commit actual values. Set them in the Vercel project dashboard
# under Settings → Environment Variables, then `vercel env pull .env.local`.

# Supabase (shared HobbyPulse project, mewstro_ prefix tables)
NEXT_PUBLIC_SUPABASE_URL=https://nspgvdytqsvnmbitbmey.supabase.co
SUPABASE_SERVICE_ROLE_KEY=... # service_role key from Supabase dashboard

# Teacher dashboard shared password (demo-level auth for Ellie pilot)
TEACHER_DASHBOARD_PASSWORD=... # pick something simple for the demo

# Base URL for redirects (logout route). Optional — defaults to localhost in dev.
NEXT_PUBLIC_SITE_URL=https://app-landings.vercel.app

# Tealium iQ — account/profile published in TiQ dashboard.
# Loads https://tags.tiqcdn.com/utag/<account>/<profile>/<env>/utag.js at runtime.
# Use 'dev' locally, 'qa' on Vercel preview, 'prod' on production.
NEXT_PUBLIC_TEALIUM_ACCOUNT=services-mikey-gilson
NEXT_PUBLIC_TEALIUM_PROFILE=hobbytracker
NEXT_PUBLIC_TEALIUM_ENVIRONMENT=dev
